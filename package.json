{
  "name": "magguu-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Discord bot + admin dashboard for a media homelab (Sonarr, Radarr, Seerr, Tautulli, SABnzbd).",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:frontend": "vite",
    "build": "npm run build:frontend && tsc",
    "build:frontend": "vite build",
    "build:backend": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit && vue-tsc --noEmit -p frontend/tsconfig.json",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "better-sqlite3": "^11.7.0",
    "cheerio": "^1.2.0",
    "discord.js": "^14.16.3",
    "drizzle-orm": "^0.36.4",
    "fast-xml-parser": "^5.7.1",
    "hono": "^4.6.12",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.28.1",
    "lucide-vue-next": "^0.469.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "vue-tsc": "^2.1.10"
  }
}
