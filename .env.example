# ─── Discord ─────────────────────────────────────────────────────────────────
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# Channel IDs (right-click channel → Copy Channel ID; Dev Mode must be on).
# Leave empty on first boot, run /setup-server, then fill in the IDs.
DISCORD_CHANNEL_GRABS=
DISCORD_CHANNEL_IMPORTS=
DISCORD_CHANNEL_FAILURES=
DISCORD_CHANNEL_REQUESTS=
DISCORD_CHANNEL_APPROVALS=
DISCORD_CHANNEL_NEW_ON_PLEX=
DISCORD_CHANNEL_HEALTH=

# ─── HTTP server (incoming webhooks) ─────────────────────────────────────────
HTTP_PORT=3000
HTTP_HOST=0.0.0.0
# Shared secret required in X-Magguu-Token header on every webhook.
# Generate with: openssl rand -hex 32   (minimum 16 chars)
WEBHOOK_SECRET=

# ─── Sonarr ──────────────────────────────────────────────────────────────────
SONARR_URL=http://sonarr:8989
SONARR_API_KEY=

# ─── Radarr ──────────────────────────────────────────────────────────────────
RADARR_URL=http://radarr:7878
RADARR_API_KEY=

# ─── Seerr (Jellyseerr / Overseerr) ──────────────────────────────────────────
SEERR_URL=http://seerr:5055
SEERR_API_KEY=

# ─── SABnzbd ─────────────────────────────────────────────────────────────────
SAB_URL=http://sabnzbd:8080
SAB_API_KEY=

# ─── Runtime ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=production
DATABASE_PATH=./data/bot.db
