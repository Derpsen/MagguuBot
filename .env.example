# ─── Discord (required) ──────────────────────────────────────────────────────
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# ─── HTTP server (incoming webhooks) ─────────────────────────────────────────
HTTP_PORT=3000
HTTP_HOST=0.0.0.0
# Shared secret required in X-Magguu-Token header on every /webhook/* call.
# Generate with: openssl rand -hex 32   (minimum 16 chars)
WEBHOOK_SECRET=

# GitHub webhook HMAC secret. Set the same value in each repo's
# Settings → Webhooks → Secret. Leave empty to disable /webhook/github.
GITHUB_WEBHOOK_SECRET=

# ─── Sonarr ──────────────────────────────────────────────────────────────────
SONARR_URL=http://sonarr:8989
SONARR_API_KEY=

# ─── Radarr ──────────────────────────────────────────────────────────────────
RADARR_URL=http://radarr:7878
RADARR_API_KEY=

# ─── Seerr (Jellyseerr / Overseerr) ──────────────────────────────────────────
SEERR_URL=http://seerr:5055
SEERR_API_KEY=

# ─── SABnzbd ─────────────────────────────────────────────────────────────────
SAB_URL=http://sabnzbd:8080
SAB_API_KEY=

# ─── Runtime ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=production
DATABASE_PATH=./data/bot.db

# ─── Engagement ──────────────────────────────────────────────────────────────
# Starboard: how many unique ⭐ reactions trigger a post to #starboard.
STARBOARD_THRESHOLD=3
STARBOARD_EMOJI=⭐
# Automod: delete messages containing Discord invite links (mods bypass).
AUTOMOD_INVITE_FILTER=true

# ─── Dashboard (optional — leave empty to disable admin dashboard) ──────────
# Discord Developer Portal → OAuth2 → Client Secret (reset, then paste).
# Also add your DASHBOARD_BASE_URL/auth/callback to the Redirects list there.
DISCORD_CLIENT_SECRET=
# Random 32+ hex. Signs the HTTP-only session cookie.
# Generate with: openssl rand -hex 32
SESSION_SECRET=
# Comma-separated Discord user IDs allowed to log in.
ADMIN_USER_IDS=
# Public URL where the dashboard is reachable. Used to build the OAuth
# redirect URI. Must exactly match Developer Portal redirect entry.
DASHBOARD_BASE_URL=https://your-bot.example.com

# ─── Optional channel-ID overrides ───────────────────────────────────────────
# Normally you DON'T set these. /setup-server writes channel IDs straight
# into SQLite (table channel_config). These env vars are only read as a
# fallback when the DB row is missing — handy for debugging or for forcing
# a specific channel without running the setup command.
#
# DISCORD_CHANNEL_GRABS=
# DISCORD_CHANNEL_IMPORTS=
# DISCORD_CHANNEL_FAILURES=
# DISCORD_CHANNEL_REQUESTS=
# DISCORD_CHANNEL_APPROVALS=
# DISCORD_CHANNEL_NEW_ON_PLEX=
# DISCORD_CHANNEL_HEALTH=
# DISCORD_CHANNEL_WELCOME=
# DISCORD_CHANNEL_AUDIT_LOG=
# DISCORD_CHANNEL_MOD_LOG=
# DISCORD_CHANNEL_GITHUB=
